# 选择使用的 LLM Provider: anthropic 或 openai
# 注：Kimi (Moonshot)、DeepSeek、SiliconFlow 等国内模型均使用 openai 兼容模式
LLM_PROVIDER=openai

# Anthropic API Key（用于 Claude 3.5 Sonnet / Claude 3 Opus 等）
# 也适用于 Kimi (Moonshot) Anthropic 兼容接口
ANTHROPIC_API_KEY=sk-ant-api03-...

# Anthropic 自定义 Base URL（国内模型兼容接口时使用）
# Kimi Anthropic 兼容: https://api.moonshot.cn/anthropic
ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic

# OpenAI API Key（如需使用 GPT-4 / GPT-4o）
# 也适用于 Kimi、DeepSeek 等 OpenAI 兼容接口
OPENAI_API_KEY=sk-...

# OpenAI 自定义 Base URL
# Kimi OpenAI 兼容: https://api.moonshot.cn/v1
# DeepSeek: https://api.deepseek.com/v1
# SiliconFlow: https://api.siliconflow.cn/v1
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 默认模型名称
# Claude: claude-3-5-sonnet-20241022
# Kimi: moonshot-v1-32k / kimi-k2-6
# DeepSeek: deepseek-chat
# GPT: gpt-4o
DEFAULT_MODEL=kimi-k2-6
